---
import { ICONS } from "../../../icons/IconAll.astro";
import { getIconComponent } from "../../../icons/IconAll.astro";

type Technology = {
  icon?: string;
};

export interface Props {
  title: string;
  img: string;
  description: string;
  technologies?: Technology[];
  link: string;
  link2: string;
  isRecent?: boolean;
  isVibeCoding?: boolean;
}

const { technologies, title, img, description, link, link2, isRecent, isVibeCoding } = Astro.props;
---

<li class="li-project">
  <div class="image-container">
    <img src={img} alt={title} loading="lazy" class="project-image" />
    {isRecent && <span class="badge-recent">Reciente</span>}
  </div>
  <div class="project-content">
    <h3 class="project-title">{title}</h3>
    <p class="project-description">{description}</p>
    
    {isVibeCoding ? (
      <div class="vibe-coding-container">
        <p class="project-technologies-title">Realizado con</p>
        <span class="vibe-coding-tag">#VibeCoding</span>
      </div>
    ) : (
      <>
        <p class="project-technologies-title">Tecnologías usadas</p>
        <div class="project-technologies">
          {
            technologies?.map(({ icon }) => {
              if(!icon) return;
              const IconComponent = getIconComponent(icon);
              return <span class="technology-icon">{IconComponent && <IconComponent />}</span>;
            })
          }
        </div>
      </>
    )}

    <div class="grid grid-cols-2 gap-3 mt-auto">
      <a href={link} target="_blank" class="project-link">Repositorio</a>
      <a href={link2} target="_blank" class="project-link">Ver más</a>
    </div>
  </div>
</li>

<style>
  .li-project {
    list-style: none;
    background: linear-gradient(145deg, #1c1c24, #23232d);
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.4);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    height: 100%;
    max-width: 500px;
    min-height: 450px;
  }

  .li-project:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 12px 20px rgba(0, 0, 0, 0.6);
  }

  .image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9; /* Forzamos un aspect ratio consistente */
    overflow: hidden;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Cambiado de fill a cover para alineación perfecta */
    border-bottom: 2px solid #0099ff;
    transition: opacity 0.3s ease;
  }

  .badge-recent {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #0099ff;
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(0, 153, 255, 0.4);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }

  .li-project:hover .project-image {
    opacity: 0.9;
  }

  .project-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1; /* Permite que el contenido crezca para empujar el botón al final */
  }

  .project-title {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 10px;
    text-transform: capitalize;
    font-family: "Nunito Sans", serif;
  }

  .project-description {
    font-size: 16px;
    color: #b0b0b0;
    line-height: 1.6;
    margin-bottom: 20px;
    font-family: "Roboto", sans-serif;
    flex-grow: 1; /* Permite que la descripción ocupe el espacio necesario */
  }

  .project-technologies-title {
    font-size: 18px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 10px;
  }

  .project-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: 20px;
  }

  .vibe-coding-container {
    margin-bottom: 20px;
  }

  .vibe-coding-tag {
    display: inline-block;
    color: #00ccff;
    font-weight: 800;
    font-size: 20px;
    font-family: "Nunito Sans", serif;
    background: rgba(0, 153, 255, 0.1);
    padding: 2px 10px;
    border-radius: 4px;
    border: 1px dashed rgba(0, 204, 255, 0.3);
  }

  .technology-icon {
    font-size: 24px;
    color: #0099ff;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .technology-icon:hover {
    transform: scale(1.2);
    color: #00ccff;
  }

  .project-link {
    padding: 12px 18px;
    text-align: center;
    background: linear-gradient(90deg, #0099ff, #00ccff);
    color: #ffffff;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 16px;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .project-link:hover {
    background: linear-gradient(90deg, #00ccff, #0099ff);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }
</style>
